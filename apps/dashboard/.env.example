VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Server-side: matches packages/convex/convex/http.ts INTERNAL_API_SECRET
INTERNAL_API_SECRET=replace-with-shared-secret
# Server-side Convex deployment URL (same value as VITE_CONVEX_URL); set both
# so the server function does not depend on the client-exposed VITE_* var.
CONVEX_URL=https://your-project.convex.cloud
