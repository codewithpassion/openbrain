# OpenBrains — consolidated environment variables.
#
# Variables are grouped by the workspace that consumes them. Real values
# for the MCP Worker go into `wrangler secret put ...` (production) or
# `apps/mcp/.env.local` (local dev). The dashboard uses `apps/dashboard/.env.local`
# locally and `wrangler.jsonc` vars + secrets in production. The CLI reads
# OB_* from the user's shell. Smoke-test invokers (scripts/smoke.ts) read
# OB_* + OB_SMOKE_* from the shell.

# -------- MCP Worker (apps/mcp) ----------------------------------------------
# Public Convex deployment URL.
CONVEX_URL=
# Embedding model id (Workers AI). 1024-dim, 4096-token Qwen3 by default.
EMBEDDING_MODEL=@cf/qwen/qwen3-embedding-0.6b
# Clerk OAuth IdP — Worker delegates the /authorize UI to Clerk.
CLERK_DOMAIN=
CLERK_JWKS_URL=
CLERK_CLIENT_ID=
CLERK_CLIENT_SECRET=
# Shared secret for the Worker → Convex internal HTTP surface.
# Must match the value Convex reads from process.env.INTERNAL_API_SECRET.
INTERNAL_API_SECRET=
# 32+ random bytes; signs device-flow bearer tokens AND the approval cookie.
DEVICE_FLOW_SECRET=
# OpenRouter API key for metadata extraction (optional in v1 if disabled).
OPENROUTER_API_KEY=

# -------- Dashboard (apps/dashboard) -----------------------------------------
VITE_CONVEX_URL=
VITE_CLERK_PUBLISHABLE_KEY=
# Server-only (set via wrangler secret put in prod, .env.local in dev).
CLERK_SECRET_KEY=

# -------- Convex (packages/convex) -------------------------------------------
# Set by `bunx convex dev` / `bunx convex deploy` — usually in a project-local
# .env.local managed by the Convex CLI, not exported here.
CONVEX_DEPLOYMENT=
# Used by tests and the dashboard. Same value as CONVEX_URL above.
# Mirrored here for clarity.

# -------- CLI / smoke test (scripts/, apps/cli) ------------------------------
# Production MCP Worker URL (e.g. https://ob-mcp.<account>.workers.dev).
OB_SERVER_URL=
# Bearer minted by `ob login`. Lives at ~/.config/ob/credentials.json;
# the smoke script reads the file automatically if this is unset.
OB_ACCESS_TOKEN=
# Set to 1 to dump every MCP request/response from scripts/smoke.ts.
OB_SMOKE_VERBOSE=0
# Set to 1 to run scripts/smoke.ts against the in-process mock MCP server
# (no Cloudflare/Convex/Clerk required). Used by CI.
OB_SMOKE_MOCK=0
# Set to 1 to print stack traces from `ob` CLI commands.
OB_DEBUG=0
